{
  "manifest_version": 3,
  "name": "Channel Debt",
  "version": "0.0.1",
  "description": "See how many unwatched videos you're behind on for any YouTube channel.",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/@*/videos"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
